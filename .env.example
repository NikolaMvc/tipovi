# ─────────────────────────────────────────────────────────────
# Football Prediction App — environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# --- Database (PostgreSQL) ---
# Local docker-compose default:
DATABASE_URL=postgresql+psycopg2://tipovi:tipovi@localhost:5432/tipovi
# For quick local dev without Postgres you may use SQLite:
# DATABASE_URL=sqlite:///./tipovi.db

# --- Redis cache ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=1800

# --- Weather (OpenWeatherMap, free tier) ---
# Get a key at https://openweathermap.org/api  (leave blank to disable weather factor)
OPENWEATHER_API_KEY=

# --- Scraping ---
SCRAPER_RATE_LIMIT_MIN=1.0
SCRAPER_RATE_LIMIT_MAX=2.0
SCRAPER_MAX_RETRIES=3

# --- Worker / scheduler ---
SCRAPE_INTERVAL_HOURS=6
REFRESH_INTERVAL_HOURS=1
SETTLE_INTERVAL_HOURS=2
LOOKAHEAD_DAYS=3
RUN_SCRAPE_ON_STARTUP=true

# --- Monte Carlo ---
MC_SIMULATIONS=10000
MC_SEED=                # leave blank for random; set int for reproducible runs

# --- API / CORS ---
# Comma-separated list of allowed origins for the frontend
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Frontend (Vite) — set in frontend/.env ---
# VITE_API_URL=http://localhost:8000
