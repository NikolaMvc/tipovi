# ─────────────────────────────────────────────────────────────
# PredictAI — local workflow env. Copy to .env (never commit .env).
# ─────────────────────────────────────────────────────────────

# --- Data (football-data.org, free tier) — REQUIRED for real data ---
# Register: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# --- Weather (OpenWeatherMap, free) — optional ---
OPENWEATHER_API_KEY=

# --- Run window ---
LOOKAHEAD_DAYS=3       # today + next 2 days
ROLLING_DAYS=3         # keep last N days of predictions/results/tips
TIP_COUNT=20           # auto top-N tips per day

# --- Monte Carlo ---
MC_SIMULATIONS=10000
MC_SEED=               # blank = random; set int for reproducible runs

# --- Scraping ---
SCRAPER_RATE_LIMIT_MIN=1.0
SCRAPER_RATE_LIMIT_MAX=2.0
SCRAPER_MAX_RETRIES=3

# --- Frontend (set in frontend/.env if needed) ---
# Not required: the frontend reads static /data/*.json from the same origin.
